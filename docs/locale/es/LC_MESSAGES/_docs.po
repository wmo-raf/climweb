msgid "How to Create a Chart Snippet"
msgstr "Cómo crear un fragmento de gráfico"

#: ../../_docs/manage_atlas/Create-Snippets.md:30
msgid ""
"![ClimWeb Atlas](../../_static/images/atlas/access_charts.png \"ClimWeb "
