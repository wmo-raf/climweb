#: ../../_docs/manage_settings/Manage-Menus.md:15
msgid ""
"Handle (Use this field to optionally specify an additional value for each "
"menu item, which you can then reference in custom menu templates.)"
msgstr ""
"Shikilia (Tumia sehemu hii ili kubainisha kwa hiari thamani ya ziada kwa "
"kila kipengee cha menyu, ambacho unaweza kisha kurejelea katika violezo vya "
"menyu maalum.)"

#: ../../_docs/manage_settings/Manage-Menus.md:16
msgid "Submenu visibility option"
msgstr "Chaguo la mwonekano wa menyu ndogo"

