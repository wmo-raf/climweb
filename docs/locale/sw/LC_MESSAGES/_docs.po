msgstr "Dhibiti Vipengee vya Menyu"

#: ../../_docs/manage_settings/Manage-Menus.md:20
msgid "Managing Footer Navigation"
msgstr "Kusimamia Urambazaji wa Chini"

#: ../../_docs/manage_settings/Manage-Menus.md:22
msgid "![Footer](../../_static/images/menus/footer_preview.png \"Footer\")"
msgstr "![Chini](../../_static/images/menus/footer_preview.png \"Footer\")"

#: ../../_docs/manage_settings/Manage-Menus.md:22
