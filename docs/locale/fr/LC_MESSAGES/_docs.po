msgstr "![Panneau dynamique](../../_static/images/surveys/question-types-dynamic-panel.png \"Panneau dynamique\")"

#: ../../_docs/manage_content_assets/Manage-Surveys.md:65
msgid "Dynamic Panel"
msgstr "Panneau dynamique"

