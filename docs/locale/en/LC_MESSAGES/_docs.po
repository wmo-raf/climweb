msgid "SMTP_EMAIL_HOST_USER"
msgstr "SMTP_EMAIL_HOST_USER"

#: ../../_docs/technical/development/environmental-variables.md
msgid ""
"Username to use for the SMTP server defined in `SMTP_EMAIL_HOST`. If empty, "
"Django won’t attempt authentication."
msgstr ""
"Username to use for the SMTP server defined in `SMTP_EMAIL_HOST`. If empty, "
"Django won’t attempt authentication."

