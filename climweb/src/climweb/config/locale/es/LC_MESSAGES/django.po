#: climweb/src/climweb/config/templates/base/style_guide.html:1127
msgid ""
"<strong>Note:</strong> <code>--primary-color-light</code> and\n"
"                    <code>--primary-color-medium</code> in base.html are hex+alpha composites (the primary color hexwith\n"
"                    an alpha suffix), different from the <code>primary-light</code> / <code>primary-medium</code>values\n"
"                    in <code>tokens.json</code> which are fully opaque mixed colors. Use the opaque mix variantsfor\n"
"                    mobile apps where alpha compositing behaves differently over non-white\n"
"                    backgrounds."
msgstr ""
"<strong>Nota:</strong> <code>--primary-color-light</code> y\n"
"                    <code>--primary-color-medium</code> en base.html son compuestos hexadecimal+alfa (el color primario hexwith\n"
"                    un sufijo alfa), diferente de los valores <code>primary-light</code> / <code>primary-medium</code>\n"
"                    en <code>tokens.json</code> que son colores mixtos completamente opacos. Utilice las variantes de mezcla opaca para\n"
"                    aplicaciones móviles donde la composición alfa se comporta de manera diferente a la que no es blanca\n"
"                    antecedentes."

