#: climweb/src/climweb/pages/shortlinks/forms.py:25
msgid "URL to shorten"
msgstr "URL ለማሳጠር"

#: climweb/src/climweb/pages/shortlinks/models.py:24
msgid "Created in admin"
msgstr "በአስተዳዳሪ የተፈጠረ"

#: climweb/src/climweb/pages/shortlinks/models.py:25
msgid "Submitted via public form"
msgstr "በይፋዊ ቅጽ በኩል ገብቷል።"

#: climweb/src/climweb/pages/shortlinks/models.py:32
msgid "Source"
msgstr "ምንጭ"

#: climweb/src/climweb/pages/shortlinks/models.py:33
msgid ""
"Whether this link was created by a logged-in editor or submitted anonymously"
" via the public form."
msgstr "ይህ ሊንክ በገባ አርታኢ የተፈጠረ ይሁን ወይም ስም-አልባ በይፋዊ ቅጹ በኩል የገባ።"

#: climweb/src/climweb/pages/shortlinks/models.py:39
msgid "Short code"
msgstr "አጭር ኮድ"

#: climweb/src/climweb/pages/shortlinks/models.py:41
msgid ""
"Leave blank to auto-generate. Only letters, numbers, - and _ are allowed. "
"This is the part that appears after /s/ in the short link."
msgstr ""
"በራስ ለማመንጨት ባዶ ይተው። ፊደሎች፣ ቁጥሮች፣ - እና _ ብቻ ይፈቀዳሉ። ይህ በአጭር ማገናኛ ከ/ሰ/ በኋላ የሚታየው "
"ክፍል ነው።"

#: climweb/src/climweb/pages/shortlinks/models.py:47
msgid "Target URL"
msgstr "የዒላማ ዩአርኤል"

#: climweb/src/climweb/pages/shortlinks/models.py:48
msgid "The full URL this short link should redirect visitors to."
msgstr "ሙሉው ዩአርኤል ይህ አጭር አገናኝ ጎብኝዎችን ወደ እሱ ማዞር አለበት።"

#: climweb/src/climweb/pages/shortlinks/models.py:53
msgid "Label"
msgstr "መለያ"

#: climweb/src/climweb/pages/shortlinks/models.py:54
msgid "Optional note to help editors remember what this link is for."
msgstr "አዘጋጆች ይህ አገናኝ ለምን እንደሆነ እንዲያስታውሱ ለመርዳት አማራጭ ማስታወሻ።"

#: climweb/src/climweb/pages/shortlinks/models.py:58
msgid "Active"
msgstr "ንቁ"

#: climweb/src/climweb/pages/shortlinks/models.py:59
msgid "Untick to disable this short link without deleting it."
msgstr "ይህን አጭር ሊንክ ሳይሰርዙት ለማሰናከል ምልክት ያንሱ።"

#: climweb/src/climweb/pages/shortlinks/models.py:61
msgid "Click count"
msgstr "ቆጠራን ጠቅ ያድርጉ"

#: climweb/src/climweb/pages/shortlinks/models.py:62
msgid "Created at"
msgstr "የተፈጠረው በ"

#: climweb/src/climweb/pages/shortlinks/models.py:70
msgid "Created by"
msgstr "የተፈጠረው በ"

#: climweb/src/climweb/pages/shortlinks/models.py:81
msgid "Short Link"
msgstr "አጭር ማገናኛ"

#: climweb/src/climweb/pages/shortlinks/models.py:82
#: climweb/src/climweb/pages/shortlinks/models.py:136
msgid "Short Links"
msgstr "አጭር ማገናኛዎች"

#: climweb/src/climweb/pages/shortlinks/models.py:121
#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/shortlink_edit.html:8
msgid "Short URL"
msgstr "አጭር URL"

#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/public_shorten.html:18
msgid "Link shortener"
msgstr "ማያያዣ አጭር"

#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/public_shorten.html:19
msgid "Shorten a link"
msgstr "ማገናኛ ያሳጥሩ"

#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/public_shorten.html:21
msgid ""
"Paste a long URL below to get a short link on our domain that's easy to "
"share."
msgstr "ለመጋራት ቀላል የሆነ አጭር ሊንክ በጎራችን ላይ ለማግኘት ከዚህ በታች ረጅም URL ለጥፍ።"

#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/public_shorten.html:31
msgid "Your short link is ready"
msgstr "አጭር ማገናኛዎ ዝግጁ ነው።"

#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/public_shorten.html:37
#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/shortlink_edit.html:14
msgid "Copy"
msgstr "ቅዳ"

#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/public_shorten.html:49
msgid "Shorten link"
msgstr "ማገናኛን አሳጥር"

#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/public_shorten.html:75
#: climweb/src/climweb/pages/shortlinks/templates/shortlinks/shortlink_edit.html:32
msgid "Copied!"
msgstr "ተቀድቷል!"

#: climweb/src/climweb/pages/shortlinks/views.py:70
msgid ""
"You've reached the limit for creating short links from this location. Please"
" try again later."
msgstr "ከዚህ አካባቢ አጫጭር አገናኞችን ለመፍጠር ገደብ ላይ ደርሰዋል። እባክዎ ቆይተው እንደገና ይሞክሩ።"
