#: climweb/src/climweb/base/views.py:49
msgid "Error fetching latest version. Please try again later."
msgstr "የቅርብ ጊዜውን ስሪት ማምጣት ላይ ስህተት። እባክዎ ቆየት ብለው ይሞክሩ."

#: climweb/src/climweb/base/views.py:67
msgid "Error in extracting latest version number from the release"
msgstr "የቅርብ ጊዜውን የስሪት ቁጥር ከልቀት ማውጣት ላይ ስህተት"

#: climweb/src/climweb/base/views.py:133
msgid "No plugin name provided."
msgstr "ምንም የተሰኪ ስም አልተሰጠም።"

#: climweb/src/climweb/base/views.py:135
msgid "CMS_PLUGIN_MANAGE_HOOK_URL is not configured."
msgstr "CMS_PLUGIN_MANAGE_HOOK_URL አልተዋቀረም።"

#: climweb/src/climweb/base/views.py:141
#, python-format
msgid "Plugin '%(name)s' removal initiated. The server will restart shortly."
msgstr "Plugin '%(name)s' መወገድ ተጀመረ። አገልጋዩ በቅርቡ እንደገና ይጀምራል።"

#: climweb/src/climweb/base/views.py:146
msgid ""
"Error sending remove command. Check that CMS_PLUGIN_MANAGE_HOOK_URL is "
"reachable."
msgstr ""
"የማስወገድ ትዕዛዝ በመላክ ላይ ስህተት። CMS_PLUGIN_MANAGE_HOOK_URL ሊደረስበት የሚችል መሆኑን ያረጋግጡ።"

#: climweb/src/climweb/base/wagtail_hooks.py:131
